<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher background — full-bleed Cinema-dark canvas with a soft
  blue vignette in the upper-left so the icon doesn't read as a flat black
  square. The radial gradient is anchored to (34,34) instead of the centre
  so launchers that crop into a circle / squircle / teardrop still surface
  the warmth, and any of them keeps the deep `#0B0F17` corners that match
  Scaffold backgrounds inside the app.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="34"
                android:centerY="34"
                android:gradientRadius="92">
                <item android:offset="0.0"  android:color="#3B6FCC" />
                <item android:offset="0.45" android:color="#161B26" />
                <item android:offset="1.0"  android:color="#0B0F17" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
