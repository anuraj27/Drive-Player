<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome silhouette used by Android 13+ themed icons. The launcher
  recolours it from the user's wallpaper, so every visible bit must be
  the same `#FFFFFF` (paint) — multi-coloured silhouettes ignore the OS
  tint and look broken under "Themed icons" mode.

  We mirror the foreground layout (back card, front card, play
  triangle) with these tweaks for the silhouette pass:
   • Back card uses fillAlpha=0.45 to keep the stack readable when the
     launcher tints the whole shape a single hue.
   • Play triangle is "punched out" of the front card via evenOdd so
     the tinted background of the icon reads through the triangle —
     same visual hierarchy as the colour foreground but inverted, which
     is what Android's themed-icon guide recommends for player glyphs.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Back card — same path as the colour foreground, just lower alpha. -->
    <path
        android:pathData="M44,32 h32 a12,12 0 0 1 12,12 v32 a12,12 0 0 1 -12,12 h-32 a12,12 0 0 1 -12,-12 v-32 a12,12 0 0 1 12,-12 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45" />

    <!-- Front card with the play triangle subtracted (evenOdd fill rule). -->
    <path
        android:fillType="evenOdd"
        android:pathData="M38,26 h32 a12,12 0 0 1 12,12 v32 a12,12 0 0 1 -12,12 h-32 a12,12 0 0 1 -12,-12 v-32 a12,12 0 0 1 12,-12 z M42,38 L42,70 L70,54 z"
        android:fillColor="#FFFFFF" />
</vector>
